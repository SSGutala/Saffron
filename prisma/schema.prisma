generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String
  name                String?
  picture             String?
  plan                Plan     @default(FREE)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  onboardingCompleted Boolean  @default(false)
  onboardingStep      Int      @default(0)
}

enum Plan {
  FREE
  PRO
}

enum LifecycleState {
  INTAKE
  BRIEF_READY
  DESIGNS_READY
  BUILDING
  APP_READY
}

model Project {
  id                 String          @id @default(uuid())
  name               String
  displayName        String?
  userId             String
  lifecycleState     LifecycleState  @default(INTAKE)
  currentPhase       String?
  briefJson          String?
  stylePreviewsJson  String?
  chosenStyleJson    String?
  inspirationImages  String?
  sourcePrompt       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  messages           Message[]
  artifacts          Artifact[]
  connectors         ProjectConnector[]
  activityEvents     ActivityEvent[]
}

enum ArtifactKind {
  DOCUMENT
  DIAGRAM
  DESIGN
  SPREADSHEET
  PRESENTATION
}

enum ArtifactStatus {
  DRAFT
  APPROVED
  SUPERSEDED
}

enum ConnectorProvider {
  NATIVE
  FIGMA
  GOOGLE_DOCS
  GOOGLE_SHEETS
  GOOGLE_SLIDES
  LUCIDCHART
}

model Artifact {
  id                   String            @id @default(uuid())
  projectId            String
  project              Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId               String
  kind                 ArtifactKind
  artifactType         String
  stageKey             String?
  stageOrder           Int?
  title                String
  description          String?
  content              String            @default("{}")
  version              Int               @default(1)
  status               ArtifactStatus    @default(DRAFT)
  sourcePrompt         String?
  sourceType           String            @default("native")
  syncStatus           String            @default("native")
  owner                String?
  dependenciesJson     String?
  relatedArtifactsJson String?
  externalUrl          String?
  previewAvailable     Boolean           @default(true)
  lastSyncedAt         DateTime?
  connectorProvider    ConnectorProvider @default(NATIVE)
  connectorEmbedUrl    String?
  connectorExternalUrl String?
  fileUrls             String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model ProjectConnector {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connectorId String
  status      String   @default("mock")
  configJson  String?
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, connectorId])
}

model ActivityEvent {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventType   String
  title       String
  metadataJson String?
  createdAt   DateTime @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  RESULT
  ERROR
}

model Message {
  id        String      @id @default(uuid())
  content   String
  role      MessageRole
  type      MessageType
  cardType  String?
  metadata  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  fragment  Fragment?
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Fragment {
  id         String   @id @default(uuid())
  messageId  String   @unique
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  sandboxUrl String   @default("sandpack")
  title      String
  files      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Usage {
  key    String    @id
  points Int
  expire DateTime?
}
